#!/usr/bin/env bash

set -Eeuo pipefail

score=0
rounds=10

randint() {
	[[ "$#" == 2 ]] || {
		echo "Usage: randint <min> <max>" >&2
		return 1
	}
	local min="$1" max="$2"
	local re='^-?[0-9]+$'
	if ! [[ "$min" =~ $re ]] || ! [[ "$max" =~ $re ]]; then
		echo "Error: Arguments must be integers." >&2
		return 1
	fi
	if (( min > max )); then
		echo "Error: Min cannot be greater than Max." >&2
		return 1
	fi
	echo $(( RANDOM % (max - min + 1) + min ))
}

game_number_guess() {
	local target
	target=$(randint 1 10)
	local guess=""
	local attempts=0 max_attempts=5 points_earned=0
	game_name="Number Guess"
	echo "$game_name. Guess my number between 1 and 10."
	while (( attempts < max_attempts )); do
		read -r guess
		if [[ ! "$guess" =~ ^[0-9]+$ ]]; then
			echo "That's not a number. Try again."
			continue
		fi
		(( ++attempts ))
		if (( guess == target )); then
			echo "You got it! The number was $target."
			case "$attempts" in
				1) points_earned=50 ;;
				2) points_earned=$(randint 38 42) ;;
				3) points_earned=$(randint 28 32) ;;
				4) points_earned=$(randint 15 19) ;;
				5) points_earned=$(randint 8 10) ;;
			esac
			break
		elif (( guess < target )); then
			echo "Too low!"
		else
			echo "Too high!"
		fi
	done
	if [[ "$guess" -ne "$target" ]]; then
		echo "You're out of guesses! The number was $target."
		points_earned=-10
	fi
	if (( points_earned > 0 )); then
		echo "You gained $points_earned points."
	else
		echo "You lost ${points_earned#-} points."
	fi
	(( score += points_earned )) || :
}

play_session() {
	score=0
	local game_pool=(
		"game_number_guess"
	)
	local session_list
	session_list=$(printf "%s\n" "${game_pool[@]}" | shuf -r -n "$rounds")
	local count=1
	for current_game in $session_list; do
		clear
		echo "Round $count of $rounds."
		$current_game
		(( ++count )) || :
		echo "Current score: $score."
		echo "Press any key for the next round."
		read -rsn 1
	done
	clear
	echo "Game over. Total score: $score."
	echo "Press any key to return to menu."
	read -rsn 1
}

show_intro() {
	clear
	cat <<-EOF
	Welcome to TermaGames, a small collection of Bash minigames.
	To start playing, press enter. To exit, press escape.
	EOF
}

wait_for_start() {
	local key
	while true; do
		show_intro
		read -rsn 1 key
		case "$key" in
			"") return 0 ;;
			$'\e') exit 0 ;;
		esac
	done
}

while true; do
	if wait_for_start; then
		play_session
	fi
done
