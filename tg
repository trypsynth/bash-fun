#!/usr/bin/env bash

set -Eeuo pipefail

score=0
rounds=10

randint() {
	[[ "$#" == 2 ]] || {
		echo "Usage: randint <min> <max>" >&2
		return 1
	}
	local min="$1" max="$2"
	local re='^-?[0-9]+$'
	if ! [[ "$min" =~ $re ]] || ! [[ "$max" =~ $re ]]; then
		echo "Error: Arguments must be integers." >&2
		return 1
	fi
	if (( min > max )); then
		echo "Error: Min cannot be greater than Max." >&2
		return 1
	fi
	echo $(( RANDOM % (max - min + 1) + min ))
}

game_equality() {
	local risk_choice
	echo "Equality. You have an equal chance of doubling your points, gaining 3000 points, or losing EVERYTHING."
	echo "Would you like to take the risk? (y/n)"
	read -rsn 1 risk_choice
	if [[ "${risk_choice,,}" != "y" ]]; then
		return 0
	fi
	local outcome
	outcome=$(randint 1 3)
	case "$outcome" in
		1)
			echo "LUCKY! Points doubled!"
			(( score *= 2 )) || :
			;;
		2)
			echo "Nice! Gained 3000 points!"
			(( score += 3000 )) || :
			;;
		3)
			echo "OUCH. Points go back to 0."
			score=0
			;;
	esac
}

game_higher_lower() {
	local current next guess points_earned=0
	current=$(randint 1 13)
	next=$(randint 1 13)
	while (( next == current )); do
		next=$(randint 1 13)
	done
	echo "Higher or Lower. The current number is: $current."
	echo "Do you think the next number will be higher or lower? (h=higher, l=lower):"
	while true; do
		read -rsn 1 guess
		case "${guess,,}" in
			h)
				if (( next > current )); then
					echo "Correct! The number was $next."
					points_earned=30
				else
					echo "Wrong! The number was $next."
					points_earned=-15
				fi
				break
				;;
			l)
				if (( next < current )); then
					echo "Correct! The number was $next."
					points_earned=30
				else
					echo "Wrong! The number was $next."
					points_earned=-15
				fi
				break
				;;
		esac
	done
	(( score += points_earned )) || :
}

game_number_guess() {
	local target
	target=$(randint 1 100)
	local guess=""
	local attempts=0 max_attempts=7 points_earned=0
	echo "Number Guess. You have $max_attempts tries to guess my number from 1 to 100."
	while (( attempts < max_attempts )); do
		read -r guess
		if [[ ! "$guess" =~ ^[0-9]+$ ]]; then
			echo "That's not a number. Try again."
			continue
		fi
		(( ++attempts ))
		if (( guess == target )); then
			echo "You got it! The number was $target."
			points_earned=$(( 60 - (attempts * 10) ))
			break
		elif (( guess < target )); then
			echo "Too low!"
		else
			echo "Too high!"
		fi
	done
	if [[ "$guess" -ne "$target" ]]; then
		echo "You're out of guesses! The number was $target."
		points_earned=-10
	fi
	(( score += points_earned )) || :
}

game_rps() {
	local options=("rock" "paper" "scissors")
	local ai_choice="${options[$(randint 0 2)]}"
	local user_choice="" points_earned=0 key=""
	echo "Rock Paper Scissors. Press r for rock, p for paper, or s for scissors."
	while true; do
		read -rsn 1 key
		case "${key,,}" in
			r) user_choice="rock"; break ;;
			p) user_choice="paper"; break ;;
			s) user_choice="scissors"; break ;;
		esac
	done
	if [[ "$user_choice" == "$ai_choice" ]]; then
		echo "It's a tie! We both chose $ai_choice."
		points_earned=0
	elif [[ ("$user_choice" == "rock" && "$ai_choice" == "scissors") || ("$user_choice" == "paper" && "$ai_choice" == "rock") || ("$user_choice" == "scissors" && "$ai_choice" == "paper") ]]; then
		echo "You win! $user_choice beats $ai_choice."
		points_earned=30
	else
		echo "You lose! $ai_choice beats $user_choice."
		points_earned=-10
	fi
	(( score += points_earned )) || :
}

play_session() {
	score=0
	local game_pool=(
		"game_equality"
		"game_higher_lower"
		"game_number_guess"
		"game_rps"
	)
	local session_list
	session_list=$(printf "%s\n" "${game_pool[@]}" | shuf -r -n "$rounds")
	local count=1
	for current_game in $session_list; do
		clear
		echo "Round $count of $rounds."
		local prev_score=$score
		$current_game
		local diff=$(( score - prev_score ))
		if (( diff > 0 )); then
			echo "You gained $diff points."
		elif (( diff < 0 )); then
			echo "You lost ${diff#-} points."
		fi
		if (( count < rounds )); then
			echo "Current score: $score."
			echo "Press Enter for the next round."
			read -rs
		fi
		(( ++count )) || :
	done
	echo "Game over. Final score: $score."
	echo "Would you like to play again? y/n"
	while true; do
		read -rsn 1 choice
		case "${choice,,}" in
			y) return 0 ;;
			n) echo "Thanks for playing!"; exit 0 ;;
		esac
	done
}

show_intro() {
	clear
	cat <<-EOF
	Welcome to TermaGames, a small collection of Bash minigames.
	To start playing, press enter. To exit, press escape.
	EOF
}

wait_for_start() {
	local key
	show_intro
	while true; do
		read -rsn 1 key
		case "$key" in
			"") return 0 ;;
			$'\e') exit 0 ;;
		esac
	done
}

wait_for_start
while true; do
	play_session
done
