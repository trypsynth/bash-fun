#!/usr/bin/env bash

set -euo pipefail

format_time() {
	local total_seconds=$1
	local days=$(( total_seconds / 86400 ))
	local hours=$(( (total_seconds % 86400) / 3600 ))
	local minutes=$(( (total_seconds  % 3600) / 60 ))
	local seconds=$(( total_seconds % 60 ))
	local units=()
	add_unit() {
		local val=$1
		local label=$2
		if (( val > 0 )); then
			[[ $val -gt 1 ]] && label="${label}s"
			units+=("$val $label")
		fi
	}
	add_unit "$days" "day"
	add_unit "$hours" "hour"
	add_unit "$minutes" "minute"
	add_unit "$seconds" "second"
	if [[ ${#units[@]} -eq 0 ]]; then
		echo "0 seconds"
		return
	fi
	local count=${#units[@]}
	case $count in
		1)
			echo "${units[0]}"
			;;
		2)
			echo "${units[0]} and ${units[1]}"
			;;
		*)
			local result=""
			for (( i = 0; i < count - 1; i++ )); do
				result+="${units[i]}"
			done
			echo "$result"
			;;
	esac
}

echo "Stopwatch started. Press space to see the elapsed time, or enter to stop."
SECONDS=0
while true; do
	if IFS= read -rsn 1 -t 0.1 char; then
		if [[ -z "$char" ]]; then
			echo -e "\nStopped, final time $(format_time "$SECONDS")."
			exit 0
		fi
		if [[ "$char" == " " ]]; then
			echo "$(format_time "$SECONDS") elapsed."
		fi
	fi
done
