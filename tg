#!/usr/bin/env bash

set -Eeuo pipefail

score=0
rounds=10

randint() {
	[[ "$#" == 2 ]] || {
		echo "Usage: randint <min> <max>" >&2
		return 1
	}
	local min="$1" max="$2"
	local re='^-?[0-9]+$'
	if ! [[ "$min" =~ $re ]] || ! [[ "$max" =~ $re ]]; then
		echo "Error: Arguments must be integers." >&2
		return 1
	fi
	if (( min > max )); then
		echo "Error: Min cannot be greater than Max." >&2
		return 1
	fi
	echo $(( RANDOM % (max - min + 1) + min ))
}

game_number_guess() {
	local target
	target=$(randint 1 10)
	local guess=""
	local attempts=0 max_attempts=5 points_earned=0
	game_name="Number Guess"
	echo "$game_name. Guess my number between 1 and 10."
	while (( attempts < max_attempts )); do
		read -r guess
		if [[ ! "$guess" =~ ^[0-9]+$ ]]; then
			echo "That's not a number. Try again."
			continue
		fi
		(( ++attempts ))
		if (( guess == target )); then
			echo "You got it! The number was $target."
			case "$attempts" in
				1) points_earned=50 ;;
				2) points_earned=40 ;;
				3) points_earned=30 ;;
				4) points_earned=17 ;;
				5) points_earned=9 ;;
			esac
			break
		elif (( guess < target )); then
			echo "Too low!"
		else
			echo "Too high!"
		fi
	done
	if [[ "$guess" -ne "$target" ]]; then
		echo "You're out of guesses! The number was $target."
		points_earned=-10
	fi
	(( score += points_earned )) || :
}

game_rps() {
	local options=("rock" "paper" "scissors")
	local ai_choice="${options[$(randint 0 2)]}"
	local user_choice="" points_earned=0 key=""
	echo "Rock, Paper, Scissors! Press r, p, or s:"
	while true; do
		read -rsn 1 key
		case "${key,,}" in
			r) user_choice="rock"; break ;;
			p) user_choice="paper"; break ;;
			s) user_choice="scissors"; break ;;
		esac
	done
	if [[ "$user_choice" == "$ai_choice" ]]; then
		echo "It's a tie! We both chose $ai_choice."
		points_earned=0
	elif [[ ("$user_choice" == "rock" && "$ai_choice" == "scissors") || ("$user_choice" == "paper" && "$ai_choice" == "rock") || ("$user_choice" == "scissors" && "$ai_choice" == "paper") ]]; then
		echo "You win! $user_choice beats $ai_choice."
		points_earned=30
	else
		echo "You lose! $ai_choice beats $user_choice."
		points_earned=-10
	fi
	(( score += points_earned )) || :
}

play_session() {
	score=0
	local game_pool=(
		"game_number_guess"
		"game_rps"
	)
	local session_list
	session_list=$(printf "%s\n" "${game_pool[@]}" | shuf -r -n "$rounds")
	local count=1
	for current_game in $session_list; do
		clear
		echo "Round $count of $rounds."
		local prev_score=$score
		$current_game
		local diff=$(( score - prev_score ))
		if (( diff > 0 )); then
			echo "You gained $diff points."
		elif (( diff < 0 )); then
			echo "You lost ${diff#-} points."
		fi
		if (( count < rounds )); then
			echo "Current score: $score."
			echo "Press Enter for the next round."
			read -rs
		fi
		(( ++count )) || :
	done
	echo "Game over. Final score: $score."
	echo "Would you like to play again? y/n"
	while true; do
		read -rsn 1 choice
		case "${choice,,}" in
			y) return 0 ;;
			n) echo "Thanks for playing!"; exit 0 ;;
		esac
	done
}

show_intro() {
	clear
	cat <<-EOF
	Welcome to TermaGames, a small collection of Bash minigames.
	To start playing, press enter. To exit, press escape.
	EOF
}

wait_for_start() {
	local key
	show_intro
	while true; do
		read -rsn 1 key
		case "$key" in
			"") return 0 ;;
			$'\e') exit 0 ;;
		esac
	done
}

wait_for_start
while true; do
	play_session
done
